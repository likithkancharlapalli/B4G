PORT=4000
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional fallback if you do not use service role key:
# SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_VENDORS_TABLE=vendors
SUPABASE_ALERTS_TABLE=alerts
SUPABASE_PORTS_TABLE=ports
SUPABASE_ROUTES_TABLE=routes
SUPABASE_ROUTES_SRID=3857
IMPORT_ROUTES_CHUNK_SIZE=250
NEWS_JOB_TOKEN=change-me-to-a-long-random-token
NEWS_JOB_MIN_INTERVAL_SEC=90
NEWS_STALE_THRESHOLD_HOURS=8
NEWS_MAX_ARTICLES=40
NEWS_MIN_ROUTE_MATCH_SCORE=2
NEWS_IMPACT_MAX_AGE_DAYS=10
NEWS_MAX_IMPACT_PER_ARTICLE=2.8
NEWS_DEFAULT_SOURCE_RELIABILITY=0.65
NEWS_LLM_ENABLED=false
NEWS_LLM_MODEL=gpt-4.1-mini
# Optional for LLM enrichment:
# OPENAI_API_KEY=sk-...
# Optional for Gemini route optimizer:
# GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ROUTE_OPTIMIZER_ENABLED=true
GEMINI_TIMEOUT_MS=6000
GEMINI_MAX_CANDIDATES=6
GEMINI_MAX_DECISIONS_PER_REQUEST=12
# Demo-only: synthesize realistic safer detours when no same-endpoint alternative exists.
DEMO_SYNTHETIC_SAFER_ROUTE_ENABLED=true
# Optional table override:
# SUPABASE_JOB_RUNS_TABLE=job_runs
# Comma-separated RSS feeds for ingestion job.
NEWS_RSS_FEEDS=https://news.google.com/rss/search?q=shipping+route+disruption+OR+port+closure+OR+maritime+strike&hl=en-US&gl=US&ceid=US:en,https://news.google.com/rss/search?q=canal+blockage+OR+port+congestion+OR+vessel+delay&hl=en-US&gl=US&ceid=US:en
